# LLM Provider: openai (기본값) | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# Anthropic (LLM_PROVIDER=anthropic 설정 시 필요)
# pip install langchain-anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6

# Embeddings
EMBED_MODEL=text-embedding-3-small

# Vector store: memory (기본값) | qdrant
VECTOR_STORE=memory
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=app_docs
# 임베딩 모델 차원과 반드시 일치 (text-embedding-3-small = 1536)
# QDRANT_VECTOR_SIZE=1536

# RAG 파라미터
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_K=4

# Agent 파라미터
MAX_AGENT_STEPS=10
SYSTEM_PROMPT=You are a helpful assistant.

# 세션 (인메모리, 단일 워커 가정 — 스케일아웃 시 외부 저장소 필요)
MAX_SESSIONS=1000
SESSION_TTL_SECONDS=3600

# HTTP / 보안
# 쉼표 구분 출처. 비우면 CORS 비활성
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 비우면 검증 안 함. 설정 시 모든 API에 헤더 필요: X-API-Key: <값>
# API_KEY=
# 업로드 최대 크기 (bytes)
# MAX_UPLOAD_BYTES=10485760

# 개발/테스트 (true 설정 시 API 키 없이 실행 가능)
MOCK_MODE=false
